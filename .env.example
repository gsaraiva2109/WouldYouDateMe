# Copy to .env and fill in. The container reads these at runtime.

# --- ntfy (push notification when she answers) ---
# Base URL of your ntfy server (no trailing slash needed)
NTFY_URL=https://ntfy.example.com
# The topic you subscribe to on your phone
NTFY_TOPIC=my-topic
# Optional: bearer token if your ntfy topic is access-protected
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxx

# --- Notification ---
# Name shown in the push title, e.g. "<NOTIFY_NAME> respondeu!"
NOTIFY_NAME=Ela

# --- App (defaults are fine; override only if needed) ---
# PORT=3000
